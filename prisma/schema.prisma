generator client {
  provider = "prisma-client-js"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                String             @id @default(uuid())
  name              String?
  email             String?            @unique
  emailVerified     DateTime?
  image             String?
  githubUsername    String?            @unique
  isPublicProfile   Boolean            @default(true)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  accounts             Account[]
  codingAnalytics      CodingAnalytics?
  portfolioAnalysis    PortfolioAnalysis?
  repositories         Repository[]
  sessions             Session[]
  pinnedRepositories   PinnedRepository[]
}

model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Repository {
  id              String             @id @default(uuid())
  userId          String
  githubId        BigInt             @unique
  name            String
  fullName        String
  description     String?
  htmlUrl         String
  stars           Int                @default(0)
  forks           Int                @default(0)
  primaryLanguage String?
  languages       Json?
  size            Int                @default(0)
  openIssues      Int                @default(0)
  isPrivate       Boolean            @default(false)
  defaultBranch   String             @default("main")
  pushedAt        DateTime?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  user            User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  insights        RepositoryInsight?
  pins            PinnedRepository[]

  @@index([userId])
}

model PinnedRepository {
  id           String     @id @default(uuid())
  userId       String
  repositoryId String
  order        Int
  createdAt    DateTime   @default(now())
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  repository   Repository @relation(fields: [repositoryId], references: [id], onDelete: Cascade)

  @@unique([userId, repositoryId])
  @@index([userId])
}

model RepositoryInsight {
  id                 String     @id @default(uuid())
  repositoryId       String     @unique
  codeQualityScore   Int        @default(0)
  documentationScore Int        @default(0)
  performanceScore   Int        @default(0)
  securityScore      Int        @default(0)
  readabilityScore   Int        @default(0)
  summary            String
  highlights         Json
  recommendations    Json
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt
  repository         Repository @relation(fields: [repositoryId], references: [id], onDelete: Cascade)
}

model PortfolioAnalysis {
  id                    String   @id @default(uuid())
  userId                String   @unique
  overallScore          Int      @default(0)
  careerLevel           String
  primaryRole           String
  strengths             Json
  weakAreas             Json
  careerRecommendations Json
  generatedAt           DateTime @default(now())
  updatedAt             DateTime @updatedAt
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CodingAnalytics {
  id                 String   @id @default(uuid())
  userId             String   @unique
  totalCommits       Int      @default(0)
  commitsPerMonth    Json?
  dailyContributions Json?
  topLanguages       Json?
  totalStars         Int      @default(0)
  totalForks         Int      @default(0)
  lastSyncedAt       DateTime @default(now())
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// status: queued | running | completed | failed
model AnalysisJob {
  id           String   @id @default(uuid())
  userId       String
  type         String
  repositoryId String?
  status       String   @default("queued")
  result       Json?
  error        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([userId])
  @@index([userId, type, repositoryId])
}
