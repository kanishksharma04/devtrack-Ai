# Database connection URL
DATABASE_URL="postgres://username:password@hostname:5432/dbname?sslmode=require"

# NextAuth Core Settings
NEXTAUTH_SECRET="your-nextauth-secret-key-at-least-32-characters"
NEXTAUTH_URL="http://localhost:3000"

# GitHub OAuth credentials (required for real GitHub integration)
# Create a GitHub App or OAuth App at: https://github.com/settings/developers
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# Gemini API Key (required for real AI portfolio audits)
# Get a key at: https://aistudio.google.com/
GEMINI_API_KEY=""

# Secret for securing the Vercel Cron endpoint (/api/cron/sync)
# Generate with: openssl rand -hex 32
CRON_SECRET=""

# ---------------------------------------------------------------------------
# Upstash Redis — required for production rate limiting and GitHub API caching
# Create a free database at: https://upstash.com/
# Copy the REST URL and token from the Upstash console.
# ---------------------------------------------------------------------------
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Rate limiting thresholds (optional — these are the defaults)
# Max Gemini calls per user per hour
RATE_LIMIT_ANALYZE_PER_HOUR=5
# Max GitHub sync calls per user per 10 minutes
RATE_LIMIT_SYNC_PER_10MIN=3

# ---------------------------------------------------------------------------
# Inngest — required for background AI audit queue
# Sign up at: https://app.inngest.com/
# Copy signing key and event key from the Inngest dashboard after creating an app.
# For local dev, run: npx inngest-cli@latest dev
# ---------------------------------------------------------------------------
INNGEST_SIGNING_KEY=""
INNGEST_EVENT_KEY=""
